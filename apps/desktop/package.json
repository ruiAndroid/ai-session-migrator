{
  "name": "@ai-session-migrator/desktop",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "desktop:dev": "node scripts/tauri-msvc-env.mjs dev --features desktop",
    "desktop:build": "node scripts/tauri-msvc-env.mjs build --features desktop --no-bundle",
